# Copy this file to .env.local and fill in values to override viteflow.config.ts.
# .env.local is gitignored. Use it for per-developer overrides or secrets.

# Override the Webflow staging URL without editing viteflow.config.ts.
# Useful when working against a different staging site than the project default.
# WEBFLOW_STAGING_URL=https://your-site.webflow.io

# Override the dev server port.
# PORT=5173

# Any variable prefixed with VITE_ is exposed to client code via import.meta.env.
# Do NOT put secrets here — they end up in dist/main.js.
# VITE_API_URL=https://api.example.com
